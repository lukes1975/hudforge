# Environment Variables Template
# Copy this to .env.local and fill in your values

# Supabase (waitlist + database)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Replicate (AI image generation)
# Legacy generator route only; authenticated foundation works without this.
REPLICATE_API_TOKEN=r8_xxxxx

# Optional generation providers
# Authenticated /generate now requires FAL_KEY for asset generation; missing FAL_KEY fails visibly.
OPENROUTER_API_KEY=your_optional_openrouter_key
OPENROUTER_MODEL=google/gemini-2.5-flash
GEMINI_API_KEY=your_optional_gemini_key
FAL_KEY=your_optional_fal_key
FAL_MODEL=fal-ai/flux/dev

# Clerk (authentication)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Lemon Squeezy (payments)
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Resend (transactional emails)
RESEND_API_KEY=re_xxxxx
